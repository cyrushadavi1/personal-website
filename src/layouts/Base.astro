---
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import '@fontsource/vazirmatn/400.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'article';
  schema?: Record<string, unknown>;
}

const {
  title = 'Cyrus Hadavi · AI engineer',
  description =
    'Staff software engineer at Meta working on ads ranking AI. A decade of ML systems at scale, and side projects that watch basketball and read game logs.',
  image = '/og-default.png',
  ogType = 'website',
  schema,
} = Astro.props;

const path = Astro.url.pathname;
const canonical = new URL(path, Astro.site);
const socialImage = new URL(image, Astro.site);
const jsonLd = schema ?? {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Cyrus Hadavi',
  alternateName: 'کوروش',
  jobTitle: 'Staff Software Engineer',
  worksFor: { '@type': 'Organization', name: 'Meta' },
  url: new URL('/', Astro.site).toString(),
  sameAs: [
    'https://github.com/cyrushadavi1',
    'https://www.linkedin.com/in/cyrus-h-8563b435/',
  ],
  knowsAbout: ['ranking systems', 'machine learning', 'computer vision'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#101312" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Cyrus Hadavi — AI engineer" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <div class="scanlines" aria-hidden="true"></div>

    <header class="site-header">
      <a class="home-link" href="/">~/cyrus.hadavi</a>
      <nav>
        <a href="/#work" class={path.startsWith('/work') ? 'active' : ''}>work</a>
        <a href="/about" class={path.startsWith('/about') ? 'active' : ''}>about</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-links">
        <a href="mailto:cyrus@hadavi.net">email</a>
        <a href="https://github.com/cyrushadavi1">github</a>
        <a href="https://www.linkedin.com/in/cyrus-h-8563b435/">linkedin</a>
      </div>
      <p class="footer-verse">
        <span lang="fa" dir="rtl">توانا بود هر که دانا بود</span>
        <span class="verse-tr">"capable is the one who is wise" · Ferdowsi</span>
      </p>
    </footer>
  </body>
</html>
