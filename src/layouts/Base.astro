---
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import '@fontsource/vazirmatn/400.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'article';
  schema?: Record<string, unknown>;
  layout?: 'default' | 'work';
}

const {
  title = 'Cyrus Hadavi · AI engineer',
  description =
    'Staff software engineer at Meta working on ads ranking AI. A decade of ML systems at scale, plus agent systems, computer vision, and developer tools.',
  image = '/og-default.png',
  ogType = 'website',
  schema,
  layout = 'default',
} = Astro.props;

const path = Astro.url.pathname;
const canonical = new URL(path, Astro.site);
const socialImage = new URL(image, Astro.site);
const jsonLd = schema ?? {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Cyrus Hadavi',
  alternateName: 'کوروس',
  jobTitle: 'Staff Software Engineer',
  worksFor: { '@type': 'Organization', name: 'Meta' },
  url: new URL('/', Astro.site).toString(),
  sameAs: [
    'https://github.com/cyrushadavi1',
    'https://www.linkedin.com/in/cyrus-h-8563b435/',
  ],
  knowsAbout: ['ranking systems', 'machine learning', 'agent systems', 'computer vision'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#101312" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Cyrus Hadavi — AI engineer" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (() => {
        document.documentElement.classList.add('js');
        let savedTheme = null;
        try {
          savedTheme = localStorage.getItem('theme');
        } catch {
          // Storage can be unavailable in privacy-restricted contexts.
        }
        const systemTheme = window.matchMedia('(prefers-color-scheme: light)').matches
          ? 'light'
          : 'dark';
        const initialTheme = savedTheme === 'light' || savedTheme === 'dark'
          ? savedTheme
          : systemTheme;
        document.documentElement.dataset.theme = initialTheme;
      })();
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class={layout === 'work' ? 'work-layout' : undefined}>
    <div class="scanlines" aria-hidden="true"></div>

    <header class="site-header">
      <a class="home-link" href="/">~/cyrus.hadavi</a>
      <nav aria-label="Primary navigation">
        <a href="/#work" class={path.startsWith('/work') ? 'active' : ''}>work</a>
        <a href="/about" class={path.startsWith('/about') ? 'active' : ''}>about</a>
        <button
          class="theme-toggle"
          type="button"
          data-theme-toggle
          aria-label="Switch to light theme"
          aria-pressed="false"
        ><span aria-hidden="true">◐</span></button>
      </nav>
      {layout === 'work' && <span class="reading-progress" data-reading-progress aria-hidden="true"></span>}
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-links">
        <a href="mailto:cyrus@hadavi.net">email</a>
        <a href="https://github.com/cyrushadavi1">github</a>
        <a href="https://www.linkedin.com/in/cyrus-h-8563b435/">linkedin</a>
      </div>
      <p class="footer-verse">
        <span lang="fa" dir="rtl">توانا بود هر که دانا بود</span>
        <span class="verse-tr">"capable is the one who is wise" · Ferdowsi</span>
      </p>
    </footer>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const toggle = document.querySelector('[data-theme-toggle]');
        const updateThemeButton = () => {
          if (!(toggle instanceof HTMLButtonElement)) return;
          const isLight = root.dataset.theme === 'light';
          toggle.setAttribute('aria-pressed', String(isLight));
          toggle.setAttribute('aria-label', `Switch to ${isLight ? 'dark' : 'light'} theme`);
        };

        updateThemeButton();
        toggle?.addEventListener('click', () => {
          const nextTheme = root.dataset.theme === 'light' ? 'dark' : 'light';
          root.dataset.theme = nextTheme;
          updateThemeButton();
          try {
            localStorage.setItem('theme', nextTheme);
          } catch {
            // The theme still works for this page when persistence is blocked.
          }
        });

        const article = document.querySelector('.prose');
        const progress = document.querySelector('[data-reading-progress]');
        if (article instanceof HTMLElement && progress instanceof HTMLElement) {
          const updateProgress = () => {
            const start = article.offsetTop - window.innerHeight * 0.2;
            const distance = Math.max(article.offsetHeight - window.innerHeight * 0.6, 1);
            const value = Math.min(Math.max((window.scrollY - start) / distance, 0), 1);
            progress.style.setProperty('--reading-progress', String(value));
          };
          updateProgress();
          window.addEventListener('scroll', updateProgress, { passive: true });
          window.addEventListener('resize', updateProgress);
        }

        document.querySelectorAll('[data-' + 'pipeline-evolution]').forEach((evolution) => {
          if (!(evolution instanceof HTMLElement)) return;
          const range = evolution.querySelector('[data-pipeline-range]');
          const stageData = evolution.querySelector('[data-pipeline-stages]');
          const title = evolution.querySelector('[data-pipeline-title]');
          const count = evolution.querySelector('[data-pipeline-count]');
          const summary = evolution.querySelector('[data-pipeline-summary]');
          const blocks = evolution.querySelector('[data-pipeline-blocks]');
          const reasonLabel = evolution.querySelector('[data-pipeline-reason-label]');
          const reason = evolution.querySelector('[data-pipeline-reason]');
          const announcement = evolution.querySelector('[data-pipeline-announcement]');
          if (
            !(range instanceof HTMLInputElement) ||
            !(stageData instanceof HTMLScriptElement) ||
            !(title instanceof HTMLElement) ||
            !(count instanceof HTMLElement) ||
            !(summary instanceof HTMLElement) ||
            !(blocks instanceof HTMLElement) ||
            !(reasonLabel instanceof HTMLElement) ||
            !(reason instanceof HTMLElement) ||
            !(announcement instanceof HTMLElement)
          ) return;

          try {
            const stages = JSON.parse(stageData.textContent || '[]');
            if (!Array.isArray(stages) || stages.length !== 5) return;

            const renderStage = (index, shouldAnnounce = true) => {
              const stage = stages[index];
              if (!stage || !Array.isArray(stage.blocks)) return;
              const stageLabel = `Stage ${index + 1} of ${stages.length}: ${stage.title}`;
              count.textContent = `stage ${index + 1} / ${stages.length}`;
              title.textContent = stage.title;
              summary.textContent = stage.summary;
              reasonLabel.textContent = 'why it changed';
              reason.textContent = stage.reason;
              blocks.replaceChildren(
                ...stage.blocks.map((block) => {
                  const item = document.createElement('span');
                  item.className = `pipeline-block ${block.added ? 'is-new' : 'is-inherited'}`;
                  item.textContent = block.label;
                  item.setAttribute('aria-label', `${block.label}; ${block.added ? 'added at this stage' : 'retained from earlier stages'}`);
                  return item;
                })
              );
              range.setAttribute('aria-valuetext', stageLabel);
              range.style.setProperty(
                '--pipeline-progress',
                `${(index / (stages.length - 1)) * 100}%`
              );
              evolution.dataset.stage = String(index + 1);
              if (shouldAnnounce) announcement.textContent = stageLabel;
            };

            renderStage(Number(range.value), false);
            evolution.classList.add('is-enhanced');
            range.addEventListener('input', () => renderStage(Number(range.value)));
          } catch {
            evolution.classList.remove('is-enhanced');
          }
        });

        document.querySelectorAll('[data-' + 'video-play]').forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          const figure = button.closest('.media-figure');
          const video = figure?.querySelector('video');
          if (!(figure instanceof HTMLElement) || !(video instanceof HTMLVideoElement)) return;
          const setPlaying = (isPlaying) => {
            figure.classList.toggle('is-playing', isPlaying);
            button.hidden = isPlaying;
          };
          button.addEventListener('click', () => {
            video.play();
            video.focus();
          });
          video.addEventListener('playing', () => setPlaying(true));
          video.addEventListener('pause', () => setPlaying(false));
          video.addEventListener('ended', () => setPlaying(false));
        });
      })();
    </script>
  </body>
</html>
