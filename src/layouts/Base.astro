---
import '@fontsource/jetbrains-mono/latin-400.css';
import '@fontsource/jetbrains-mono/latin-700.css';
import '@fontsource/vazirmatn/arabic-400.css';
import '../styles/global.css';
import jbmRegular from '@fontsource/jetbrains-mono/files/jetbrains-mono-latin-400-normal.woff2?url';
import jbmBold from '@fontsource/jetbrains-mono/files/jetbrains-mono-latin-700-normal.woff2?url';
import vazirArabic from '@fontsource/vazirmatn/files/vazirmatn-arabic-400-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  ogType?: 'website' | 'article';
  schema?: Record<string, unknown>;
  layout?: 'default' | 'work';
  noindex?: boolean;
}

const {
  title = 'Cyrus Hadavi · AI engineer',
  description =
    'Staff software engineer at Meta working on ads ranking AI. A decade of ML systems at scale, plus ranking systems, agent systems, computer vision, and evals.',
  image = '/og-default.png',
  imageAlt = 'Cyrus Hadavi · AI engineer',
  ogType = 'website',
  schema,
  layout = 'default',
  noindex = false,
} = Astro.props;

const path = Astro.url.pathname;
const canonical = new URL(path, Astro.site);
const socialImage = new URL(image, Astro.site);
const jsonLd = schema ?? {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Cyrus Hadavi',
  alternateName: 'کوروس',
  jobTitle: 'Staff Software Engineer',
  worksFor: { '@type': 'Organization', name: 'Meta' },
  homeLocation: { '@type': 'Place', name: 'New York, NY' },
  alumniOf: { '@type': 'CollegeOrUniversity', name: 'University of Maryland' },
  email: 'mailto:cyrus@hadavi.net',
  url: new URL('/', Astro.site).toString(),
  sameAs: [
    'https://github.com/cyrushadavi1',
    'https://www.linkedin.com/in/cyrus-h-8563b435/',
  ],
  knowsAbout: ['ranking systems', 'agent systems', 'computer vision', 'evals', 'machine learning'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#101312" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f3efe6" media="(prefers-color-scheme: light)" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex ? <meta name="robots" content="noindex" /> : <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href={jbmRegular} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={jbmBold} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={vazirArabic} as="font" type="font/woff2" crossorigin />
    <script is:inline>
      (() => {
        document.documentElement.classList.add('js');
        let savedTheme = null;
        try {
          savedTheme = localStorage.getItem('theme');
        } catch {
          // Storage can be unavailable in privacy-restricted contexts.
        }
        const systemTheme = window.matchMedia('(prefers-color-scheme: light)').matches
          ? 'light'
          : 'dark';
        const initialTheme = savedTheme === 'light' || savedTheme === 'dark'
          ? savedTheme
          : systemTheme;
        document.documentElement.dataset.theme = initialTheme;
      })();
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class={layout === 'work' ? 'work-layout' : undefined}>
    <a class="skip-link" href="#main">skip to content</a>
    <div class="scanlines" aria-hidden="true"></div>

    <header class="site-header">
      <a class="home-link" href="/">~/cyrus.hadavi</a>
      <nav aria-label="Primary navigation">
        <a href="/#work" class={path.startsWith('/work') ? 'active' : ''}>work</a>
        <a href="/notes/" class={path.startsWith('/notes') ? 'active' : ''}>notes</a>
        <a href="/about/" class={path.startsWith('/about') ? 'active' : ''}>about</a>
        <a href="/resume.pdf" class="nav-resume">resume</a>
        <button
          class="theme-toggle"
          type="button"
          data-theme-toggle
          aria-label="Switch to light theme"
        ><span aria-hidden="true">◐</span></button>
      </nav>
      {layout === 'work' && <span class="reading-progress" data-reading-progress aria-hidden="true"></span>}
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-links">
        <a href="mailto:cyrus@hadavi.net">email</a>
        <a href="https://github.com/cyrushadavi1">github</a>
        <a href="https://www.linkedin.com/in/cyrus-h-8563b435/">linkedin</a>
        <a href="/resume.pdf">resume</a>
        <a href="/colophon/">colophon</a>
      </div>
      <p class="footer-verse">
        <span lang="fa" dir="rtl">توانا بود هر که دانا بود</span>
        <span class="verse-tr">"capable is the one who is wise" · Ferdowsi</span>
      </p>
    </footer>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const toggle = document.querySelector('[data-theme-toggle]');
        const themeColors = { dark: '#101312', light: '#f3efe6' };
        const syncThemeColor = () => {
          const theme = root.dataset.theme === 'light' ? 'light' : 'dark';
          document
            .querySelectorAll('meta[name="theme-color"]')
            .forEach((meta) => meta.setAttribute('content', themeColors[theme]));
        };
        const updateThemeButton = () => {
          if (!(toggle instanceof HTMLButtonElement)) return;
          const isLight = root.dataset.theme === 'light';
          toggle.setAttribute('aria-label', `Switch to ${isLight ? 'dark' : 'light'} theme`);
        };

        syncThemeColor();
        updateThemeButton();
        toggle?.addEventListener('click', () => {
          const nextTheme = root.dataset.theme === 'light' ? 'dark' : 'light';
          root.dataset.theme = nextTheme;
          syncThemeColor();
          updateThemeButton();
          try {
            localStorage.setItem('theme', nextTheme);
          } catch {
            // The theme still works for this page when persistence is blocked.
          }
        });
      })();
    </script>
  </body>
</html>
