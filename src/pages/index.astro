---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const work = (await getCollection('work')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base>
  <section class="hero">
    <p class="prompt-line"><span class="prompt">~</span> whoami</p>
    <h1>Cyrus Hadavi<span class="cursor" aria-hidden="true"></span></h1>
    <p class="name-fa" lang="fa" dir="rtl">کوروس</p>
    <p class="tagline">
      I build ML systems that rank ads for billions of people. On the side,
      I build systems that keep working after I put my phone down, watch
      basketball, turn game logs into useful guidance, and know when to ask.
    </p>
    <p class="role">staff software engineer · ads ranking ai @ meta · new york</p>
    <p class="specialties">ranking systems · computer vision · applied LLMs</p>
    <div class="hero-actions" aria-label="Primary links">
      <a class="button-link primary" href="#work">explore the work ↓</a>
      <a class="button-link" href="mailto:cyrus@hadavi.net">get in touch ↗</a>
    </div>
  </section>

  <section id="work">
    <h2 class="section-rule"><span class="star">✦</span> selected work</h2>
    <ol class="work-list">
      {
        work.map((entry, i) => (
          <li>
            <a href={`/work/${entry.id}`}>
              <span class="idx">{String(i + 1).padStart(2, '0')}</span>
              <span class="name">{entry.data.title}</span>
              <span class="category">{entry.data.category}</span>
              <span class="desc">{entry.data.tagline.toLowerCase()}</span>
              <span class="year">{entry.data.year}</span>
              <span class="view-project">view project →</span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <section>
    <h2 class="section-rule"><span class="star">✦</span> about</h2>
    <p style="max-width: var(--measure);">
      A decade of ML across Meta, Google, HBO Max, and Microsoft.
      Recommenders, ML platforms, and two years leading an ads-ranking
      team before returning to hands-on technical work.
      <a class="nowrap-link" href="/about">the longer version →</a>
    </p>
  </section>
</Base>
