---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Khatam from '../components/Khatam.astro';

const allWork = (await getCollection('work')).sort(
  (a, b) => a.data.order - b.data.order
);
const work = allWork.filter((entry) => entry.data.featured);
const alsoWork = allWork.filter((entry) => !entry.data.featured);
const notes = (await getCollection('notes')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base>
  <Fragment slot="intro">
    <section class="scroll-intro" data-scroll-intro aria-label="Visual introduction">
      <div class="scroll-intro-sticky">
        <video
          class="scroll-intro-media"
          data-scroll-intro-video
          poster="/website-intro-poster.jpg"
          preload="auto"
          muted
          playsinline
          tabindex="-1"
          aria-hidden="true"
        >
          <source src="/website-intro.mp4" type="video/mp4" />
        </video>
        <div class="scroll-intro-shade" aria-hidden="true"></div>
        <a class="scroll-intro-skip" href="#main">skip intro <span aria-hidden="true">↓</span></a>
        <p class="scroll-intro-hint" aria-hidden="true">
          <span>scroll to enter</span>
          <span class="scroll-intro-arrow">↓</span>
        </p>
        <span class="scroll-intro-progress" aria-hidden="true"></span>
      </div>
    </section>

    <script is:inline>
      (() => {
        const intro = document.querySelector('[data-scroll-intro]');
        const video = document.querySelector('[data-scroll-intro-video]');
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

        if (!(intro instanceof HTMLElement) || !(video instanceof HTMLVideoElement)) return;

        video.defaultMuted = true;
        video.muted = true;

        if (reduceMotion.matches) return;

        let frame = 0;
        const render = () => {
          frame = 0;
          const distance = Math.max(1, intro.offsetHeight - window.innerHeight);
          const progress = Math.min(1, Math.max(0, -intro.getBoundingClientRect().top / distance));
          intro.style.setProperty('--intro-progress', String(progress));

          if (video.readyState >= HTMLMediaElement.HAVE_METADATA && Number.isFinite(video.duration)) {
            const targetTime = Math.min(video.duration - 0.001, progress * video.duration);
            if (Math.abs(video.currentTime - targetTime) > 0.025) video.currentTime = targetTime;
          }
        };
        const requestRender = () => {
          if (!frame) frame = window.requestAnimationFrame(render);
        };

        video.addEventListener('loadedmetadata', requestRender);
        window.addEventListener('scroll', requestRender, { passive: true });
        window.addEventListener('resize', requestRender, { passive: true });
        requestRender();
      })();
    </script>
  </Fragment>

  <section class="hero">
    <p class="prompt-line"><span class="prompt">~</span> whoami</p>
    <h1>Cyrus Hadavi<span class="cursor" aria-hidden="true"></span></h1>
    <p class="name-fa"><span lang="fa" dir="rtl">کوروس</span></p>
    <p class="tagline">
      I build ranking systems that serve billions of people at Meta. On the
      side I build things that keep working while I sleep: an agent I text
      over iMessage, a pipeline that watches NBA broadcasts, a leveling
      copilot for Path of Exile. One rule everywhere: show your evidence
      or abstain.
    </p>
    <p class="role">staff software engineer · ads ranking ai @ meta · new york</p>
    <p class="specialties">ranking systems · agent systems · computer vision · evals</p>
    <div class="hero-actions">
      <a class="button-link primary" href="#work">explore the work <span aria-hidden="true">↓</span></a>
      <a class="button-link" href="/resume.pdf">resume <span aria-hidden="true">↓</span></a>
      <a class="button-link" href="mailto:cyrus@hadavi.net">get in touch <span aria-hidden="true">↗</span></a>
    </div>
  </section>

  <section id="work">
    <h2 class="section-rule"><span class="star"><Khatam /></span> selected work</h2>
    <ol class="work-list">
      {
        work.map((entry, i) => (
          <li>
            <a href={`/work/${entry.id}/`}>
              <span class="idx">{String(i + 1).padStart(2, '0')}</span>
              <span class="name" style={`view-transition-name: work-title-${entry.id}`}>{entry.data.title}</span>
              <span class="category">{entry.data.category}</span>
              <span class="desc">{entry.data.tagline.toLowerCase()}</span>
              <span class="year">{entry.data.year}</span>
              <span class="view-project">view project <span aria-hidden="true">→</span></span>
            </a>
          </li>
        ))
      }
    </ol>
    {
      alsoWork.length > 0 && (
        <ul class="also-list">
          {alsoWork.map((entry) => (
            <li>
              <a href={`/work/${entry.id}/`}>
                <span class="also-label">also</span>
                <span class="name" style={`view-transition-name: work-title-${entry.id}`}>{entry.data.title}</span>
                <span class="desc">{entry.data.tagline.toLowerCase()}</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  {
    notes.length > 0 && (
      <section id="notes">
        <h2 class="section-rule"><span class="star"><Khatam /></span> notes</h2>
        <ol class="notes-list">
          {notes.map((entry) => (
            <li>
              <a href={`/notes/${entry.id}/`}>
                <span class="name">{entry.data.title}</span>
                <span class="desc">{entry.data.description}</span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    )
  }

  <section>
    <h2 class="section-rule"><span class="star"><Khatam /></span> about</h2>
    <p class="section-teaser">
      A decade of ML across Meta, Google, HBO Max, and Microsoft.
      Recommenders, ML platforms, and two years leading a 15 engineer
      ads ranking team before going back to building things myself.
      <a class="nowrap-link" href="/about/">the longer version →</a>
    </p>
  </section>
</Base>
